{
  "name": "scraper-dashboard",
  "version": "1.0.0",
  "description": "Web Scraping Dashboard Tool — detect, scrape, and manage product data from any website",
  "main": "src/server.js",
  "bin": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js",
    "build": "pkg . --targets node20-win-x64 --output dist/ScraperDashboard.exe"
  },
  "pkg": {
    "assets": [
      "src/views/**/*",
      "src/public/**/*",
      ".env"
    ],
    "scripts": [
      "node_modules/sequelize/lib/dialects/mysql/**/*.js",
      "node_modules/axios/dist/node/axios.cjs",
      "node_modules/cheerio/dist/commonjs/**/*.js"
    ],
    "ignore": [
      "node_modules/sequelize/lib/dialects/sqlite/**",
      "node_modules/sequelize/lib/dialects/postgres/**",
      "node_modules/sequelize/lib/dialects/mssql/**",
      "node_modules/sequelize/lib/dialects/mariadb/**",
      "node_modules/sequelize/lib/dialects/snowflake/**",
      "node_modules/sequelize/lib/dialects/db2/**",
      "node_modules/sequelize/lib/dialects/ibmi/**"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.5",
    "robots-parser": "^3.0.1",
    "sequelize": "^6.35.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "nodemon": "^3.0.2"
  }
}
